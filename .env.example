# CPA - Variables de Entorno
# Copiar a .env y rellenar con valores reales

# ========================================
# APLICACIÓN
# ========================================
NODE_ENV=development
PORT=3000

# ========================================
# BASE DE DATOS
# ========================================
DATABASE_URL=postgresql://cpa:cpa_local@localhost:5432/cpa_dev

# ========================================
# JWT (ACCESS TOKEN: 8h, REFRESH: 7d)
# ========================================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<64-chars-random>
JWT_REFRESH_SECRET=<64-chars-random>

# ========================================
# FRONTEND
# ========================================
FRONTEND_URL=http://localhost:5173

# ========================================
# SMTP (EMAIL)
# ========================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=<usuario-smtp>
SMTP_PASS=<contraseña-smtp>
SMTP_FROM=noreply@cpa.local

# ========================================
# REDIS
# ========================================
REDIS_URL=redis://localhost:6379

# ========================================
# ALMACENAMIENTO DE ARCHIVOS
# ========================================
STORAGE_TYPE=local
# STORAGE_TYPE=s3 (producción)
# S3_BUCKET=<nombre-bucket>
# S3_REGION=<region>
# S3_ACCESS_KEY=<access-key>
# S3_SECRET_KEY=<secret-key>

# ========================================
# AZURE AD (Opcional - futuro)
# ========================================
# AZURE_CLIENT_ID=<client-id>
# AZURE_TENANT_ID=<tenant-id>
# AZURE_CLIENT_SECRET=<client-secret>
